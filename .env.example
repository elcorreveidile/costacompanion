# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # NUNCA exponer al cliente — solo en servidor

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Stripe del operador (cuotas a acompañantes y anunciantes) ─────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Precios acompañante
STRIPE_PRICE_ACOMP_LAUNCH=          # 19 €/mes (tarifa lanzamiento, primer año)
STRIPE_PRICE_ACOMP_STANDARD=        # 39 €/mes (tarifa estándar, a partir del 2.º año)
STRIPE_PRICE_ACOMP_SETUP=           # 99 € único (alta)

# Precios anunciante (Local Partner)
STRIPE_PRICE_PARTNER_BASIC=         # 29 €/mes
STRIPE_PRICE_PARTNER_FEATURED=      # 79 €/mes

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://costacompanion.com
